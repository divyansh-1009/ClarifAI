# Google Gemini API Key for assessment generation
GOOGLE_API_KEY=your_google_api_key_here

# Pinecone Configuration for vector embeddings
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=clarif-ai

# Django Secret Key (keep this secret in production)
SECRET_KEY=your_django_secret_key_here

# Database (if using PostgreSQL in production)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
